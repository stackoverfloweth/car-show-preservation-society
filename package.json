{
  "name": "csps-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Car Show Preservation Society monorepo",
  "scripts": {
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "type-check": "pnpm -r run type-check",
    "dev:api": "pnpm --filter @csps/api dev",
    "dev:web": "pnpm --filter @csps/web dev",
    "build:web": "pnpm --filter @csps/web build",
    "db:generate": "pnpm --filter @csps/db db:generate",
    "db:migrate": "pnpm --filter @csps/db db:migrate",
    "db:push": "pnpm --filter @csps/db db:push",
    "db:studio": "pnpm --filter @csps/db db:studio",
    "db:seed": "pnpm --filter @csps/db db:seed"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
